global
    log /dev/log local0
    daemon

defaults
    log global
    mode tcp
    timeout connect 5s
    timeout client  1m
    timeout server  1m

frontend wazuh_front
    bind *:1514
    mode tcp
    default_backend wazuh_back

backend wazuh_back
    mode tcp
    balance leastconn
    option tcp-check

    server mgr1 192.168.3.101:1514 check
    server mgr2 192.168.3.102:1514 check
    server mgr3 192.168.3.103:1514 check
    server mgr4 192.168.3.104:1514 check